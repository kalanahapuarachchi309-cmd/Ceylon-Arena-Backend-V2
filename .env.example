NODE_ENV=development
PORT=5000
APP_NAME=Ceylon Arena API
API_PREFIX=/api/v1

# MongoDB Connection
# IMPORTANT: Include database name in connection string
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/ceylon-arena

# JWT Secrets - Generate strong random strings (min 16 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-very-strong-access-secret
JWT_REFRESH_SECRET=replace-with-very-strong-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cookie Configuration
# IMPORTANT FOR PRODUCTION:
# - Use hostname only (no https://, no trailing slash)
# - Use .domain.com (with leading dot) for cross-subdomain support
# - Leave empty for localhost development
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Client/Frontend URL - NO TRAILING SLASH
CLIENT_URL=http://localhost:5173

# CORS Origins - Comma-separated, NO TRAILING SLASHES
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin Seed (Optional - for initial setup in development only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# Security Settings
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
MAX_FILE_SIZE_MB=5

# ============================================
# PRODUCTION VERCEL EXAMPLE:
# ============================================
# NODE_ENV=production
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/ceylon_arena?retryWrites=true&w=majority
# JWT_ACCESS_SECRET=your-super-secret-32-char-string
# JWT_REFRESH_SECRET=your-super-secret-32-char-string
# COOKIE_DOMAIN=.ceylonarena.com
# COOKIE_SECURE=true
# CLIENT_URL=https://www.ceylonarena.com
# CORS_ORIGINS=https://www.ceylonarena.com,https://ceylonarena.com
# (plus all Cloudinary vars)
